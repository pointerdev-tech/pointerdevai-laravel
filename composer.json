{
  "name": "pointerdev/ai-chat-laravel",
  "description": "Official Laravel client package for PointerDev AI chat APIs.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "pointerdevai",
    "laravel",
    "chat",
    "sdk"
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "PointerDev\\AIChat\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PointerDev\\AIChat\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist"
  },
  "extra": {
    "laravel": {
      "providers": [
        "PointerDev\\AIChat\\AIChatServiceProvider"
      ],
      "aliases": {
        "AIChat": "PointerDev\\AIChat\\Facades\\AIChat"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
